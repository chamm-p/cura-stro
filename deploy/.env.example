# ─── cura-stro — Beispielkonfiguration ───
# cp .env.example .env  und Werte anpassen.

# ── Ports (Host) ──
FRONTEND_PORT=9601
BACKEND_PORT=9605

# Öffentliche Basis-URL (für OIDC-Redirect / Links).
PUBLIC_BASE_URL=http://localhost:9601

# ── Datenbank ──
POSTGRES_DB=curastro
POSTGRES_USER=curastro
POSTGRES_PASSWORD=please-change-me

# ── JWT ──
# Erzeugen:  python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_64_char_hex_string_please_change_me_now_0123456789

# ── Lokaler Fallback-User (Single-User-Absicherung ohne Keycloak) ──
DEFAULT_USER_ENABLED=true
DEFAULT_USER_USERNAME=astro
DEFAULT_USER_EMAIL=astro@example.com
DEFAULT_USER_PASSWORD=change-me

# ── OIDC / Keycloak (optional; leer lassen = nur lokaler Login) ──
# Gleiche Keycloak-Instanz wie curai, ABER eigener Client + Secret + Redirect.
# Discovery: Realm-Basis genügt (well-known wird automatisch angehängt).
#   OIDC_DISCOVERY_URL=https://keycloak.example.org/realms/dein-realm
#   OIDC_CLIENT_ID=cura-stro
#   OIDC_CLIENT_SECRET=...
#   OIDC_REDIRECT_URI=http://localhost:9601/login
#   OIDC_PROVIDER_LABEL=Keycloak
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:9601/login
OIDC_PROVIDER_LABEL=Keycloak

# ── MCP-Server (für externe LLMs wie curai) ──
# Token für den /mcp-Endpunkt. Leer = MCP deaktiviert.
# Erzeugen:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_TOKEN=

# ── Vision-LLM (curai-Gateway) für meteoblue-Wolken (optional) ──
# Liest die Wolken-Schichten (tief/mittel/hoch) aus dem meteoblue-Seeing-
# Screenshot. Leer = aus (Fallback Open-Meteo). OpenAI-kompatibel.
# Aktualisiert 1×/Tag automatisch (deckt ~3 Tage); manuell per Kachel ↻.
LLM_GATEWAY_URL=
LLM_TOKEN=
LLM_VISION_MODEL=original/Qwen3.6
CLOUD_REFRESH_ENABLED=true
# Feste Uhrzeit (lokale Zeit des Standorts) für den täglichen Refresh:
CLOUD_REFRESH_HOUR=16

# ── Foto-Archiv (V2-Workflow) ──
# Der NAS wird NICHT mehr per OS-Mount eingehängt, sondern direkt aus der App
# per SMB angesprochen — Zugang (Host/Share/Pfad/User/Passwort) konfigurierst
# du im UI unter Einstellungen → Archiv & ASIAir (mit „Verbindung testen").
#
# Diese Variablen betreffen nur den LOKALEN Fallback-Speicher (Modus „Lokales
# Volume"): Container-Pfad des Archivs (Default reicht).
ARCHIVE_ROOT=/archive
# Optional: lokalen Host-Pfad statt Docker-Volume als /archive binden.
#   ARCHIVE_PATH=/mnt/astro
ARCHIVE_PATH=

# ── PixInsight Mac-Agent (Batch-Verarbeitung) ──
# Der Mac-Agent läuft auf dem Mac, auf dem PixInsight installiert ist.
# Er nimmt Verarbeitungs-Jobs vom Backend entgegen und startet PixInsight
# headless (WBPP). Der Mac braucht KEINEN SMB-Mount — alle Dateien werden
# über HTTP transferiert (Backend liest NAS → zip → Agent → Ergebnis-zip →
# Backend schreibt NAS).
# Leer = PixInsight-Integration deaktiviert.
PIXINSIGHT_AGENT_URL=http://192.168.1.100:7777
# Shared-Secret zwischen Backend und Mac-Agent (muss auf beiden Seiten gleich sein).
# Erzeugen:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
PIXINSIGHT_AGENT_TOKEN=
